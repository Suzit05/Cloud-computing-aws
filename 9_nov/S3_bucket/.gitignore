# Local .terraform directories
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files (these often contain secrets)
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore plan output files
*.tfplan
*.plan

# Ignore lock file if you don't want to version it (optional)
# .terraform.lock.hcl

# Ignore sensitive variable files
*.auto.tfvars

# Ignore backend config files (if you keep creds here)
backend.tfvars
backend.hcl

# MacOS / Linux temp files
.DS_Store
*.swp
*.tmp

# VSCode settings (optional)
.vscode/

# JetBrains IDEs (optional)
.idea/
