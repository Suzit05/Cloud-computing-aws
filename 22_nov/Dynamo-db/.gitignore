# Terraform working directory
.terraform/

# Terraform state files (VERY IMPORTANT)
*.tfstate
*.tfstate.*

# Terraform crash logs
crash.log
crash.*.log

# Terraform variable files (often contain secrets)
*.tfvars
*.tfvars.json

# Terraform plan output
*.tfplan

# CLI configuration files
.terraformrc
terraform.rc

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Lock file (OPTIONAL – usually committed)
# Uncomment if you do NOT want to commit it
# .terraform.lock.hcl
